<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="bg.tu_varna.sit.winefactory.presentation.controllers.UserManagementController">

    <children>
        <Label layoutX="30.0" layoutY="20.0" text="Manage Users"
               style="-fx-font-size: 20px; -fx-font-weight: bold;" />

        <Label layoutX="30.0" layoutY="80.0" text="Username:" />
        <TextField fx:id="usernameField" layoutX="140.0" layoutY="76.0" prefWidth="220.0" />

        <Label layoutX="30.0" layoutY="120.0" text="Password:" />
        <PasswordField fx:id="passwordField" layoutX="140.0" layoutY="116.0" prefWidth="220.0" />

        <Label layoutX="30.0" layoutY="160.0" text="Role:" />
        <ComboBox fx:id="roleComboBox" layoutX="140.0" layoutY="156.0" prefWidth="220.0" />

        <Button layoutX="30.0" layoutY="220.0" text="Add User" onAction="#onAddUser" />
        <Button layoutX="120.0" layoutY="220.0" text="Delete User" onAction="#onDeleteUser" />
        <Button layoutX="220.0" layoutY="220.0" text="Clear" onAction="#onClearFields" />
        <Button layoutX="290.0" layoutY="220.0" text="Back" onAction="#onBackToDashboard" />

        <Label fx:id="messageLabel" layoutX="30.0" layoutY="270.0" prefWidth="330.0" />

        <ListView fx:id="userListView" layoutX="410.0" layoutY="76.0" prefHeight="280.0" prefWidth="230.0" />
    </children>
</AnchorPane>