<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="bg.tu_varna.sit.winefactory.presentation.controllers.BottleTypeController">

    <children>
        <Label layoutX="30.0" layoutY="20.0" text="Manage Bottle Types"
               style="-fx-font-size: 20px; -fx-font-weight: bold;" />

        <Label layoutX="30.0" layoutY="80.0" text="Bottle size (ml):" />
        <ComboBox fx:id="sizeComboBox" layoutX="180.0" layoutY="76.0" prefWidth="200.0" />

        <Label layoutX="30.0" layoutY="120.0" text="Quantity:" />
        <TextField fx:id="quantityField" layoutX="180.0" layoutY="116.0" prefWidth="200.0" />

        <Label layoutX="30.0" layoutY="160.0" text="Critical minimum:" />
        <TextField fx:id="criticalMinimumField" layoutX="180.0" layoutY="156.0" prefWidth="200.0" />

        <Button layoutX="30.0" layoutY="220.0" mnemonicParsing="false" onAction="#onAddBottleType" text="Add" />
        <Button layoutX="100.0" layoutY="220.0" mnemonicParsing="false" onAction="#onUpdateBottleType" text="Update" />
        <Button layoutX="190.0" layoutY="220.0" mnemonicParsing="false" onAction="#onDeleteBottleType" text="Delete" />
        <Button layoutX="280.0" layoutY="220.0" mnemonicParsing="false" onAction="#onClearFields" text="Clear" />
        <Button layoutX="360.0" layoutY="220.0" mnemonicParsing="false" onAction="#onBackToDashboard" text="Back" />

        <Label fx:id="messageLabel" layoutX="30.0" layoutY="270.0" prefWidth="500.0" />

        <ListView fx:id="bottleTypeListView" layoutX="420.0" layoutY="76.0" prefHeight="180.0" prefWidth="220.0" />
    </children>
</AnchorPane>